<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.passwordmanager.controller.PasswordDialogController"
      spacing="14"
      stylesheets="@../css/styles.css">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <!-- Título -->
    <VBox spacing="6">
        <Label text="Título" styleClass="field-label"/>
        <TextField fx:id="titleField"
                   promptText="Ej: Gmail, GitHub, Netflix..."
                   styleClass="input-field"/>
    </VBox>

    <!-- Usuario -->
    <VBox spacing="6">
        <Label text="Usuario / Email" styleClass="field-label"/>
        <TextField fx:id="usernameField"
                   promptText="Ej: usuario@email.com"
                   styleClass="input-field"/>
    </VBox>

    <!-- Contraseña -->
    <VBox spacing="6">
        <Label text="Contraseña" styleClass="field-label"/>
        <HBox spacing="8">
            <PasswordField fx:id="passwordField"
                           promptText="Contraseña"
                           styleClass="input-field"
                           HBox.hgrow="ALWAYS"/>
            <Button text="Generar"
                    onAction="#handleGenerate"
                    styleClass="secondary-button"/>
        </HBox>
    </VBox>

    <!-- Opciones del generador -->
    <TitledPane fx:id="generatorPane"
                text="Opciones del generador"
                expanded="false"
                styleClass="generator-pane">
        <VBox spacing="10">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>

            <!-- Longitud -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Longitud:" styleClass="field-label"/>
                <Slider fx:id="lengthSlider"
                        min="8" max="64" value="16"
                        showTickLabels="true" showTickMarks="true"
                        majorTickUnit="16" snapToTicks="false"
                        HBox.hgrow="ALWAYS"/>
                <Label fx:id="lengthLabel" text="16" styleClass="field-label"/>
            </HBox>

            <!-- Checkboxes -->
            <HBox spacing="16">
                <CheckBox fx:id="chkUppercase"  text="Mayúsculas" selected="true"/>
                <CheckBox fx:id="chkNumbers"    text="Números"    selected="true"/>
                <CheckBox fx:id="chkSymbols"    text="Símbolos"   selected="true"/>
            </HBox>
        </VBox>
    </TitledPane>

    <!-- Mensaje de error -->
    <Label fx:id="errorLabel" styleClass="error-label" wrapText="true"/>

    <!-- Botones -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancelar"
                onAction="#handleCancel"
                styleClass="secondary-button"/>
        <Button fx:id="saveButton"
                text="Guardar"
                onAction="#handleSave"
                styleClass="primary-button"/>
    </HBox>

</VBox>